library(glmnet)
library(corpcor)
DATA_DIR <- "~/data/staph_gwas"
RESULTS_DIR <- "~/data/staph_gwas/results/real_data/susie"
# with tree, fixed
# read in gene file
G <- readRDS(file.path(DATA_DIR, "gpa.rds"))
scale_G <- scale(G, center = TRUE, scale = FALSE)
# read in phenotype
phen <- readRDS(file.path(DATA_DIR, "phens.rds"))
# names of samples
samples <- rownames(G)
# variant names
variants <- colnames(G)
# names of different phenotypes
phen_names <- colnames(phen)[4:19]
# extra sample
extra <- setdiff(phen$tag, samples)
phen <- phen[which(phen$tag != extra),]
# susieR
ord <- match(samples, phen$tag)
phen_reordered <- as.data.frame(phen[ord, , drop = FALSE])
phenotype = "Ery"
current_phen <- phen_reordered[, phenotype]
# identify missing phenotypes
mod_phen <- current_phen[!is.na(current_phen)]
mod_G <- G[!is.na(current_phen),]
data <- list(X = mod_G, y = mod_phen)
result <- mGWAS::tower_gcm(data = data, fit_X = mGWAS::fit_X_shrinkage,
fit_y_given_X = mGWAS::fit_y_given_X_lasso)
load_all()
load_all()
result <- mGWAS::tower_gcm(data = data, fit_X = mGWAS::fit_X_shrinkage,
fit_y_given_X = mGWAS::fit_y_given_X_lasso)
load_all()
result <- mGWAS::tower_gcm(data = data, fit_X = mGWAS::fit_X_shrinkage,
fit_y_given_X = mGWAS::fit_y_given_X_lasso)
View(data)
# Extract the data.
X <- data$X
y <- data$y
# number of samples and predictors
n <- nrow(X)
p <- ncol(X)
# Create K roughly equally size folds
folds <- sample(x = 1:K, size = n, replace = TRUE) |>
R.utils::withSeed(seed = seed)
seed = 1234
# Create K roughly equally size folds
folds <- sample(x = 1:K, size = n, replace = TRUE) |>
R.utils::withSeed(seed = seed)
K = 2
# Create K roughly equally size folds
folds <- sample(x = 1:K, size = n, replace = TRUE) |>
R.utils::withSeed(seed = seed)
# Matrix of product of residuals across folds
product_residuals <- matrix(0,nrow = n, ncol = p)
k = 1
print(paste0("Fitting Nuisance Fold ", k))
# Segment data by fold using the which() function
evalIndexes <- which(folds==k,arr.ind=TRUE)
# evaluation data
evalDataX <- X[evalIndexes, ]
evalDataY <- y[evalIndexes]
# nuisance training data
if (K > 1) {
nuisDataX <- X[-evalIndexes, ]
nuisDataY <- y[-evalIndexes]
} else if (K == 1) {
nuisDataX <- evalDataX
nuisDataY <- evalDataY
}
# Concatenate all of the training data
data_nuis <- list(X = nuisDataX, y = nuisDataY)
# number of evaluation samples
nk <- length(evalDataY)
# y given X fit
y_given_X_hat <- fit_y_given_X(data_nuis) |>
R.utils::withSeed(seed = seed)
fit_y_given_X = mGWAS::fit_y_given_X_lasso
# y given X fit
y_given_X_hat <- fit_y_given_X(data_nuis) |>
R.utils::withSeed(seed = seed)
fit_X = mGWAS::fit_X_shrinkage
# X fit
X_hat <- fit_X(data_nuis) |>
R.utils::withSeed(seed = seed)
j = 1
# compute E[eta^hat_j(evalDataX)|X_-j]
cond_mean_xj <- X_hat$conditional_mean(j, evalDataX)
hist(cond_mean_xj)
hist(colMeans(X))
# round to be between 0 and 1
cond_probs_xj <- pmin(pmax(cond_mean_xj, 0), 1)
condProbs <- cbind(1 - cond_probs_xj, cond_probs_xj)
condProbs <- cbind(as.vector(1 - cond_probs_xj), as.vector(cond_probs_xj))
View(condProbs)
evalDataX0j <- evalDataX
evalDataX0j[,j] <- 0
evalDataX1j <- evalDataX
evalDataX1j[,j] <- 1
# 3) Compute f(X) for each slice (dimension 3)
possible_y_X <- cbind(y_given_X_hat(evalDataX0j), y_given_X_hat(evalDataX1j))
View(possible_y_X)
# Compute the conditional mean (length n vector)
cond_mean_yj <- rowSums(possible_y_X * condProbs)  # (n x num_obs) * (n x num_obs) → sum along num_obs → (n)
load_all()
result <- mGWAS::tower_gcm(data = data, fit_X = mGWAS::fit_X_shrinkage,
fit_y_given_X = mGWAS::fit_y_given_X_lasso)
RESULTS_DIR <- "~/data/staph_gwas/results/real_data/tower_gcm"
saveRDS(result, file = file.path(RESULTS_DIR, paste0(phenotype,"_tower_gcm_lasso_results.rds")))
