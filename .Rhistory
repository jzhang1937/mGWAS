solve(5)
1/5
### OLD VERSION ###
get_submatrix_inverse_old <- function(A_inverse, j) {
A_jj_inv <- A_inverse[j, j]
A_j_inv  <- A_inverse[j, -j]
A_inv_j  <- A_inverse[-j, j]
A_inv_jj <- A_inverse[-j, -j]
A_inv_jj - A_inv_j %*% solve(A_jj_inv) %*% A_j_inv
}
### NEW VERSION ###
get_submatrix_inverse_new <- function(A_inverse, j) {
Ajj_inv  <- A_inverse[j, j]
A_j_inv  <- A_inverse[j, -j, drop = FALSE]
A_inv_j  <- A_inverse[-j, j, drop = FALSE]
A_inv_jj <- A_inverse[-j, -j, drop = FALSE]
A_inv_jj - (A_inv_j %*% A_j_inv) / Ajj_inv
}
### Generate Test Matrix ###
set.seed(1)
n <- 800
X <- matrix(rnorm(n^2), n, n)
A <- crossprod(X) + diag(n)
A_inverse <- solve(A)
### Repeated calls to amplify timing differences
j_vals <- sample.int(n, 200)
cat("Old version timing:\n")
time_old <- system.time({
for (jj in j_vals) {
get_submatrix_inverse_old(A_inverse, jj)
}
})
print(time_old)
cat("\nNew version timing:\n")
time_new <- system.time({
for (jj in j_vals) {
get_submatrix_inverse_new(A_inverse, jj)
}
})
print(time_new)
cat("\nSpeedup factor:\n")
print(time_old["elapsed"] / time_new["elapsed"])
