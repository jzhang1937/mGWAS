# read in tree
tree <- readRDS(file.path(DATA_DIR, "tree.rds"))
samples <- rownames(G)
mod_G <- scale(G, center = TRUE, scale = TRUE)
n <- nrow(mod_G)
mod_G <- mod_G * sqrt((n - 1) / n)
# AR similarity matrix
similarity <- rho^abs(outer(1:n, 1:n, "-"))
set.seed(1234)
i = 1
perm <- sample(1:n)
keep_cols <- sample(1:ncol(mod_G), p)
subset_mod_G <- mod_G[,keep_cols]
causal_indices <- sample(1:p, s)
causal_names <- colnames(subset_mod_G)[causal_indices]
info <- list(keep_indices = keep_cols, keep_names = colnames(subset_mod_G), ind = causal_indices, name = causal_names)
sign <- 2 * rbinom(s, 1, prob = 0.5) - 1
similarity_XXT <- G %*% t(G) / 3950
correlated_noise <-  MASS::mvrnorm(n = 1, mu = rep(0, n), Sigma = tausq * similarity_XXT)
phen <- katlabutils::generate_glm_response_data(as.matrix(subset_mod_G[,causal_indices]),
as.vector(amplitude * sign), family = "gaussian")
sim_data <- list(X = subset_mod_G, y = phen + correlated_noise)
